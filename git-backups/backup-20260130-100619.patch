index b19b80e..c775d85 100644
--- a/Modules/Website/Services/SettingsService.php
+++ b/Modules/Website/Services/SettingsService.php
@@ -75,4 +75,38 @@ public function updateMany(array $data, string $group = 'general'): bool
             return false;
         }
     }
+    /**
+     * Lấy tất cả settings thuộc một group (vớ dụ: 'header')
+     * Giảm số lượng truy vấn DB và tận dụng Cache một lần
+     */
+    public function getGroup(string $group): array
+    {
+        return Cache::rememberForever("settings_group_{$group}", function () use ($group) {
+            return Setting::where('group_name', $group)
+                ->pluck('value', 'key')
+                ->toArray();
+        });
+    }
+
+    /**
+     * Cập nhật hàng loạt settings và xóa cache theo group
+     */
+    public function updateGroup(string $group, array $data): void
+    {
+        foreach ($data as $key => $value) {
+            Setting::updateOrCreate(
+                ['key' => $key],
+                [
+                    'value' => is_array($value) ? json_encode($value) : $value,
+                    'group_name' => $group
+                ]
+            );
+
+            // Xóa cache lẻ nếu Model vẫn dùng cache lẻ
+            Cache::forget("setting_{$key}");
+        }
+
+        // Xóa cache của cả group
+        Cache::forget("settings_group_{$group}");
